# -------------------------------------------------------
# ENVIRONMENT VARIABLES TEMPLATE
# -------------------------------------------------------
# 1. Copy this file and rename it to "Auth.env"
# 2. Fill in your own credentials below
# 3. "Auth.env" is git-ignored and will NEVER be committed
# -------------------------------------------------------

# Firebase Realtime Database
FIREBASE_HOST=your-project-default-rtdb.firebaseio.com
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Firebase Auth account used by the agent
AGENTE_EMAIL=agent@yourproject.local
AGENTE_PASSWORD=your_strong_password

# OpenRouter API key (https://openrouter.ai)
OPENROUTER_KEY=your_openrouter_api_key
